# ── Backend Environment ──────────────────────────────────────
# NODE_ENV không cần set local (mặc định = development)
# Trên Render: NODE_ENV=production được set trong render.yaml

# Discord OAuth
APPLICATION_ID=""
DISCORD_CLIENT_SECRET=""
JWT_SECRET=""

# Database Connection String
POOLER_URL="postgres://[db-user].[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&schema=DiscordCounselor"
DIRECT_URL="postgres://[db-user].[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres?schema=DiscordCounselor"

# URLs — production sẽ tự dùng fallback từ config/env.js
DISCORD_REDIRECT_URI="https://orias-counselor.duckdns.org:4000/api/auth/discord/callback" # Production
# DISCORD_REDIRECT_URI="http://localhost:4000/api/auth/discord/callback" # Local
# DISCORD_REDIRECT_URI="http://backend:4000/api/auth/discord/callback" # Docker

FRONTEND_ORIGIN="https://orias-counselor.duckdns.org:3000" # Production
# FRONTEND_ORIGIN="http://localhost:3000" # Local
# FRONTEND_ORIGIN="http://frontend:3000" # Docker

# Redis
REDIS_URL="redis://localhost:6379" # Local
# REDIS_URL="redis://redis:6379" # Docker

# Server port
PORT=4000