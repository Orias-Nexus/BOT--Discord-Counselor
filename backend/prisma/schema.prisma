generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POOLER_URL")
  directUrl = env("DIRECT_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model channels {
  category_id   String             @id
  category_type category_type_enum
  server_id     String
  channels_idx  Int                @default(0)
  created_at    DateTime           @default(now()) @db.Timestamptz(6)
  updated_at    DateTime           @default(now()) @db.Timestamptz(6)
  servers       servers            @relation(fields: [server_id], references: [server_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category_type], map: "idx_channels_category_type")
  @@index([server_id], map: "idx_channels_server")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model embeds {
  embed_id   String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  embed_name String
  server_id  String
  embed      Json?
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  updated_at DateTime   @default(now()) @db.Timestamptz(6)
  servers    servers    @relation(fields: [server_id], references: [server_id], onDelete: Cascade, onUpdate: NoAction)
  messages   messages[]

  @@unique([embed_name, server_id])
  @@index([embed_name, server_id], map: "idx_embeds_name_server")
  @@index([server_id], map: "idx_embeds_server")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model functions {
  script_id  String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  script     String   @unique
  slash      String?
  action     String?
  event      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([script], map: "idx_functions_script")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model levels {
  level_id   String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  level      Int      @unique
  exp        BigInt
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([level], map: "idx_levels_level")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model members {
  server_id      String
  user_id        String
  member_exp     BigInt             @default(0)
  member_level   Int                @default(0)
  member_status  member_status_enum @default(Good)
  member_expires DateTime?          @db.Timestamptz(6)
  created_at     DateTime           @default(now()) @db.Timestamptz(6)
  updated_at     DateTime           @default(now()) @db.Timestamptz(6)
  servers        servers            @relation(fields: [server_id], references: [server_id], onDelete: Cascade, onUpdate: NoAction)
  users          users              @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([server_id, user_id])
  @@index([server_id], map: "idx_members_server")
  @@index([user_id], map: "idx_members_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model messages {
  messages_id   String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  messages_type message_type_enum
  server_id     String
  channel_id    String?
  embed_id      String?           @db.Uuid
  created_at    DateTime          @default(now()) @db.Timestamptz(6)
  updated_at    DateTime          @default(now()) @db.Timestamptz(6)
  embeds        embeds?           @relation(fields: [embed_id], references: [embed_id], onUpdate: NoAction)
  servers       servers           @relation(fields: [server_id], references: [server_id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model servers {
  server_id     String     @id
  time_warn     Int        @default(0)
  time_mute     Int        @default(0)
  time_lock     Int        @default(0)
  time_new      Int        @default(0)
  role_warn     String?
  role_mute     String?
  role_lock     String?
  role_new      String?
  unrole_mute   String?
  unrole_lock   String?
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @db.Timestamptz(6)
  status        server_status_enum @default(Standard)
  channels      channels[]
  embeds        embeds[]
  members       members[]
  messages      messages[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  user_id    String    @id
  user_exp   BigInt    @default(0)
  user_level Int       @default(0)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @db.Timestamptz(6)
  members    members[]
}

/// This enum is commented in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
enum category_type_enum {
  Creator
  Stats
}

/// This enum is commented in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
enum member_status_enum {
  Newbie
  Good
  Warn
  Mute
  Lock
  Kick
  Leaved
}

enum server_status_enum {
  Standard
  Premium
  Deluxe
  Leaved
}

enum message_type_enum {
  Messages
  Greeting
  Leaving
  Boosting
  Leveling
  Logging
}
